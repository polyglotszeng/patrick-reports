# Cloudflare static-assets redirect rules.
#
# This file ONLY accepts redirect rules in the form:
#   <source> <destination> [status]
# Cache-Control / security headers do NOT go here — they live in `_headers`.
#
# Next.js static export (trailingSlash) emits per-route index.html files.
# Below: explicit routes for non-Next static pages served from the repo root.

# WorldMonitor China variant — keep entry rewrites non-redirecting so
# /worldmonitor/ cannot loop.
/worldmonitor            /worldmonitor/index.html            200
/worldmonitor/           /worldmonitor/index.html            200

# Satellite Ops dashboard — single-file SPA in its own subdirectory.
/worldmonitor/satellite-ops            /worldmonitor/satellite-ops/index.html            200
/worldmonitor/satellite-ops/           /worldmonitor/satellite-ops/index.html            200
/worldmonitor/satellite-ops/*          /worldmonitor/satellite-ops/:splat                 200