# === 全局重定向 ===
# 处理 Next.js 静态导出的 trailingSlash
# 例: /neo-labs/labs/openai → /neo-labs/labs/openai/

# === SPA fallback (非必要，因为是纯静态) ===
# 静态导出不需要 SPA fallback
# /neo-labs/labs/ 路径直接由 build 时生成的 index.html 提供

# === 缓存控制 ===
# 默认缓存静态资源 1 年
/neo-labs/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML 不缓存
/neo-labs/*.html
  Cache-Control: public, max-age=0, must-revalidate

# JSON 数据短期缓存
/neo-labs/*.json
  Cache-Control: public, max-age=300, must-revalidate

# === 安全头 ===
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
