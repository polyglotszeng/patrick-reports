{
  "name": "neo-labs-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Neo Labs Tracker - 部署到 2017zyl.xyz/neo-labs/",
  "scripts": {
    "dev": "NODE_ENV=development next dev -p 3000",
    "build": "rm -rf out && NODE_ENV=production NEXT_PUBLIC_BASE_PATH=/neo-labs next build",
    "export": "rm -rf out && NEXT_PUBLIC_BASE_PATH=/neo-labs next build && cp -r public/neo-labs out/neo-labs/",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage",
    "deploy:prep": "rm -rf out && NEXT_PUBLIC_BASE_PATH=/neo-labs next build && cp -r public/neo-labs out/neo-labs/ && ls -la out/",
    "deploy:cf": "wrangler pages deploy out --project-name=patrick-reports",
    "deploy:monorepo": "rsync -av --delete --exclude=node_modules --exclude=.next --exclude=out --exclude=.git ./ ~/patricks-reports/neo-labs/",
    "data:sync": "cp /Users/zl/Documents/neo-labs-labs.json public/neo-labs/labs.json && cp /Users/zl/Documents/neo-labs-labs.json app/data/neo-labs.json",
    "data:refresh": "node scripts/refresh-data.mjs"
  },
  "dependencies": {
    "chart.js": "4.4.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-chartjs-2": "5.2.0",
    "react-dom": "18.3.1",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.45.0",
    "@testing-library/jest-dom": "6.4.2",
    "@testing-library/react": "16.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "20.14.0",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "playwright": "1.45.0",
    "ts-jest": "^29.4.11",
    "typescript": "5.4.5",
    "wrangler": "3.65.0"
  }
}
