{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "patrick-reports",
  "compatibility_date": "2026-06-15",
  "observability": {
    "enabled": true
  },
  "pages_build_output_dir": "neo-labs-build/out/neo-labs",
  "build": {
    "command": "cd neo-labs-build && npm install --include=dev && npm run export",
    "cwd": "neo-labs-build"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
