# Cloudflare Pages _redirects for /worldmonitor/ static subpath.
# The built China variant is a static Vite SPA served under /worldmonitor/.
#
# Rules:
#   1. No catch-all wildcard — it shadows static .html files and routes
#      unknown paths back to the homepage ("investor" page).
#   2. Every static page is explicitly whitelisted to its .html file.
#   3. SPA-style client routes still 404 instead of leaking into /.
#      (CF Pages will serve the project's 404.html for unmatched paths.)

# Entry points
/worldmonitor            /worldmonitor/index.html            200
/worldmonitor/           /worldmonitor/index.html            200
/worldmonitor/dashboard  /worldmonitor/dashboard.html        200

# Static pages generated by the WorldMonitor build
/worldmonitor/embed                /worldmonitor/embed.html                 200
/worldmonitor/live-channels        /worldmonitor/live-channels.html         200
/worldmonitor/settings             /worldmonitor/settings.html              200
/worldmonitor/mcp-grant            /worldmonitor/mcp-grant.html             200
/worldmonitor/offline              /worldmonitor/offline.html               200
/worldmonitor/wm-widget-sandbox    /worldmonitor/wm-widget-sandbox.html     200

# Static pages with their own subdirectory SPA
/worldmonitor/satellite-ops        /worldmonitor/satellite-ops/index.html   200
/worldmonitor/satellite-ops/       /worldmonitor/satellite-ops/index.html   200
/worldmonitor/blog                 /worldmonitor/blog/index.html            200
/worldmonitor/blog/                /worldmonitor/blog/index.html            200
/worldmonitor/pro                  /worldmonitor/pro/index.html             200
/worldmonitor/pro/                 /worldmonitor/pro/index.html             200
/worldmonitor/pro/welcome          /worldmonitor/pro/welcome.html           200

# Note: NO /worldmonitor/* catch-all on purpose.
# Unknown paths now 404 instead of silently redirecting to the homepage.
