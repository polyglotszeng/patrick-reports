<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Satellite Ops · 全球卫星实时看板</title>
  <meta name="description" content="Live satellite tracker and Earth observation dashboard. ISS, Starlink, GPS, weather satellites, NASA GIBS imagery, active fires." />
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
  <style>
    :root {
      --bg: #050810;
      --bg-2: #0a0f1a;
      --bg-3: #111827;
      --fg: #e5e7eb;
      --fg-2: #94a3b8;
      --fg-3: #64748b;
      --accent: #00d4ff;
      --warn: #ff6b35;
      --good: #10b981;
      --danger: #ef4444;
      --line: rgba(0, 212, 255, 0.18);
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; }
    body {
      font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
      background: var(--bg);
      color: var(--fg);
      overflow: hidden;
    }
    #map { position: absolute; inset: 0; background: #0a0f1a; }
    /* MapLibre dark style overrides */
    .maplibregl-ctrl-attrib { background: rgba(5, 8, 16, 0.7) !important; color: var(--fg-3) !important; font-size: 10px !important; }
    .maplibregl-ctrl-attrib a { color: var(--fg-2) !important; }
    .maplibregl-ctrl-group { background: var(--bg-3) !important; border: 1px solid var(--line) !important; }
    .maplibregl-ctrl-group button { background-color: var(--bg-3) !important; }
    .maplibregl-ctrl-group button + button { border-top: 1px solid var(--line) !important; }
    .maplibregl-ctrl-group button .maplibregl-ctrl-icon { filter: invert(0.9) hue-rotate(180deg); }

    /* Top header */
    #header {
      position: absolute; top: 0; left: 0; right: 0; z-index: 10;
      padding: 12px 18px;
      background: linear-gradient(to bottom, rgba(5,8,16,0.92), rgba(5,8,16,0));
      pointer-events: none;
    }
    #header h1 {
      margin: 0; font-size: 14px; font-weight: 600; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--fg);
    }
    #header h1 span { color: var(--accent); }
    #header .sub {
      font-size: 11px; color: var(--fg-3); margin-top: 2px; font-variant-numeric: tabular-nums;
    }
    #header .dot {
      display: inline-block; width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); margin-right: 6px;
      box-shadow: 0 0 6px var(--accent);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.4 } }

    /* Side panel */
    #panel {
      position: absolute; top: 70px; left: 14px; z-index: 10;
      width: 280px; max-height: calc(100vh - 100px);
      background: rgba(10, 15, 26, 0.85);
      backdrop-filter: blur(8px);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 14px;
      overflow-y: auto;
      pointer-events: auto;
    }
    #panel::-webkit-scrollbar { width: 6px; }
    #panel::-webkit-scrollbar-thumb { background: var(--line); border-radius: 3px; }
    .section { margin-bottom: 14px; }
    .section h2 {
      margin: 0 0 6px; font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--accent);
    }
    .row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 4px 0; font-size: 12px; border-top: 1px solid rgba(255,255,255,0.04);
    }
    .row:first-child { border-top: none; }
    .row .label { color: var(--fg-2); }
    .row .val { color: var(--fg); font-variant-numeric: tabular-nums; font-weight: 500; }
    .toggle {
      display: flex; align-items: center; gap: 6px; padding: 4px 0;
      font-size: 12px; cursor: pointer; user-select: none;
    }
    .toggle:hover { color: var(--accent); }
    .toggle input { accent-color: var(--accent); margin: 0; }
    .badge {
      display: inline-block; padding: 1px 6px; border-radius: 3px;
      font-size: 10px; font-weight: 600; letter-spacing: 0.05em;
    }
    .badge-good { background: rgba(16, 185, 129, 0.18); color: var(--good); }
    .badge-warn { background: rgba(255, 107, 53, 0.18); color: var(--warn); }
    .badge-bad { background: rgba(239, 68, 68, 0.18); color: var(--danger); }
    .badge-neutral { background: rgba(148, 163, 184, 0.18); color: var(--fg-2); }

    /* Bottom status bar */
    #status {
      position: absolute; bottom: 14px; left: 14px; right: 14px; z-index: 10;
      background: rgba(10, 15, 26, 0.85);
      backdrop-filter: blur(8px);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 10px 14px;
      font-size: 11px; color: var(--fg-3);
      display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
      pointer-events: auto;
    }
    #status .source {
      display: flex; align-items: center; gap: 6px;
    }
    #status .source .name { color: var(--fg-2); font-weight: 500; }
    #status .source .lat { font-variant-numeric: tabular-nums; }

    /* Layer buttons */
    .layer-btn {
      display: block; width: 100%;
      padding: 6px 10px; margin-bottom: 4px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
      border-radius: 4px;
      color: var(--fg-2);
      font-size: 12px; text-align: left;
      cursor: pointer; pointer-events: auto;
      transition: all 0.15s;
    }
    .layer-btn:hover { background: rgba(0, 212, 255, 0.06); color: var(--fg); }
    .layer-btn.active {
      background: rgba(0, 212, 255, 0.12);
      border-color: var(--accent);
      color: var(--accent);
    }
    .layer-btn .meta {
      font-size: 10px; color: var(--fg-3); margin-top: 2px;
      font-variant-numeric: tabular-nums;
    }

    /* AOI buttons */
    .aoi-btn {
      display: inline-block; padding: 3px 8px; margin: 2px 2px 2px 0;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
      border-radius: 3px;
      color: var(--fg-2);
      font-size: 10px;
      cursor: pointer; pointer-events: auto;
    }
    .aoi-btn:hover { background: rgba(0, 212, 255, 0.06); color: var(--fg); }
    .aoi-btn.active { background: rgba(0, 212, 255, 0.12); border-color: var(--accent); color: var(--accent); }

    /* Loading splash */
    #splash {
      position: absolute; inset: 0; z-index: 100;
      background: var(--bg);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 16px;
      transition: opacity 0.4s;
    }
    #splash .title { font-size: 16px; letter-spacing: 0.1em; color: var(--accent); font-weight: 600; }
    #splash .progress { width: 240px; height: 4px; background: var(--bg-3); border-radius: 2px; overflow: hidden; }
    #splash .progress-bar { height: 100%; background: var(--accent); width: 0%; transition: width 0.3s; }
    #splash .status { font-size: 12px; color: var(--fg-3); font-variant-numeric: tabular-nums; min-height: 16px; }

    /* Popup */
    .maplibregl-popup-content {
      background: rgba(10, 15, 26, 0.95) !important;
      color: var(--fg) !important;
      border: 1px solid var(--line) !important;
      border-radius: 4px !important;
      padding: 10px 14px !important;
      font-family: inherit !important;
      font-size: 12px !important;
    }
    .maplibregl-popup-tip { border-top-color: rgba(10,15,26,0.95) !important; border-bottom-color: rgba(10,15,26,0.95) !important; }
    .maplibregl-popup-content h3 { margin: 0 0 4px; font-size: 13px; color: var(--accent); }
    .maplibregl-popup-content .meta { color: var(--fg-2); font-size: 11px; }
    .maplibregl-popup-content .meta b { color: var(--fg); font-variant-numeric: tabular-nums; }

    @media (max-width: 720px) {
      #panel { width: calc(100vw - 28px); max-height: 40vh; }
    }
  </style>
</head>
<body>
  <div id="splash">
    <div class="title">SATELLITE OPS</div>
    <div class="progress"><div class="progress-bar" id="progressBar"></div></div>
    <div class="status" id="splashStatus">Initializing...</div>
  </div>

  <div id="header">
    <h1><span>◉</span> Satellite Ops</h1>
    <div class="sub"><span class="dot"></span><span id="clock">--</span> · <span id="countInfo">loading...</span></div>
    <a href="/" id="backHome" style="position:absolute;top:14px;right:18px;font-size:11px;color:var(--accent);text-decoration:none;padding:4px 10px;border:1px solid var(--line);border-radius:4px;background:rgba(5,8,16,0.6);pointer-events:auto;letter-spacing:0.04em;">← 返回主页</a>
  </div>

  <div id="panel">
    <div class="section">
      <h2>卫星分组 / Constellation</h2>
      <label class="toggle"><input type="checkbox" id="grp-stations" checked /> 🛰️ 空间站 (Stations · ISS 等)</label>
      <label class="toggle"><input type="checkbox" id="grp-gps" checked /> 📡 GPS 导航星座</label>
      <label class="toggle"><input type="checkbox" id="grp-weather" checked /> ☁️ 气象卫星</label>
      <label class="toggle"><input type="checkbox" id="grp-starlink" /> 🌐 Starlink (10652 颗, 加载需 ~10s)</label>
      <label class="toggle"><input type="checkbox" id="grp-tracks" checked /> 显示 Ground Track</label>
      <label class="toggle"><input type="checkbox" id="grp-labels" /> 显示卫星名标签</label>
    </div>

    <div class="section">
      <h2>地球观测 / Earth Imagery</h2>
      <button class="layer-btn" data-layer="off">⛔ 关闭瓦片层</button>
      <button class="layer-btn active" data-layer="modis-truecolor">🌍 MODIS Terra 真彩合成</button>
      <button class="layer-btn" data-layer="viirs-nightlights">🌃 VIIRS 夜光</button>
      <button class="layer-btn" data-layer="modis-aerosol">💨 MODIS 气溶胶</button>
      <button class="layer-btn" data-layer="modis-fires-thermal">🔥 MODIS 火点 (热异常)</button>
      <button class="layer-btn" data-layer="gibs-clouds">☁️ MODIS 云覆盖</button>
      <div class="row" style="margin: 8px 0 4px;"><span class="label" style="font-size: 10px; color: var(--accent);">天气卫星 / WEATHER-SAT</span></div>
      <button class="layer-btn" data-layer="himawari-airmass">🌏 Himawari AHI 气团 (RGBA, 全彩)</button>
      <button class="layer-btn" data-layer="himawari-ir">🌏 Himawari AHI 红外 (Band13)</button>
      <button class="layer-btn" data-layer="goes-east-airmass">🌎 GOES-East ABI 气团</button>
      <button class="layer-btn" data-layer="goes-east-ir">🌎 GOES-East ABI 红外 (Band13)</button>
      <button class="layer-btn" data-layer="goes-west-airmass">🌎 GOES-West ABI 气团</button>
      <div class="row">
        <span class="label">瓦片日期</span>
        <span class="val" id="tileDate">--</span>
      </div>
      <div class="row">
        <span class="label">数据回退</span>
        <span class="val" id="tileFallback">--</span>
      </div>
    </div>

    <div class="section">
      <h2>火点数据 / Active Fires</h2>
      <div class="row">
        <span class="label">来源</span>
        <span class="val"><span class="badge badge-neutral" id="firmsStatus">FIRMS 未配置</span></span>
      </div>
      <div class="row">
        <span class="label">24h 火点</span>
        <span class="val" id="firmsCount">--</span>
      </div>
      <div class="row" style="font-size: 10px; color: var(--fg-3); margin-top: 4px;">
        在页面注入 FIRMS_MAP_KEY = "your-key" 启用
      </div>
    </div>

    <div class="section">
      <h2>关注区域 / AOI Watchlist</h2>
      <div>
        <span class="aoi-btn" data-aoi="global">🌍 全球</span>
        <span class="aoi-btn active" data-aoi="taiwan">台海</span>
        <span class="aoi-btn" data-aoi="redsea">红海</span>
        <span class="aoi-btn" data-aoi="ukraine">乌克兰</span>
        <span class="aoi-btn" data-aoi="gulf">波斯湾</span>
        <span class="aoi-btn" data-aoi="suez">苏伊士</span>
        <span class="aoi-btn" data-aoi="korea">朝鲜半岛</span>
      </div>
      <div class="row" style="margin-top: 8px;">
        <span class="label">Sentinel-2 场景 (24h)</span>
        <span class="val" id="stacCount">--</span>
      </div>
    </div>

    <div class="section">
      <h2>系统 / System</h2>
      <div class="row"><span class="label">数据源</span><span class="val">CelesTrak · NASA GIBS · Earth Search · NASA FIRMS</span></div>
      <div class="row"><span class="label">渲染</span><span class="val">MapLibre GL + deck.gl (vector-tiles 友好)</span></div>
      <div class="row"><span class="label">轨道传播</span><span class="val">satellite.js SGP4 (浏览器端)</span></div>
      <div class="row"><span class="label">build</span><span class="val">2026-06-26 v0.1.1-basemap-esri</span></div>
    </div>
  </div>

  <div id="status">
    <div class="source"><span class="name">CelesTrak</span><span class="badge badge-good" id="src-celestrak">--</span></div>
    <div class="source"><span class="name">GIBS</span><span class="badge badge-good" id="src-gibs">--</span></div>
    <div class="source"><span class="name">FIRMS</span><span class="badge badge-neutral" id="src-firms">--</span></div>
    <div class="source"><span class="name">STAC</span><span class="badge badge-good" id="src-stac">--</span></div>
    <div class="source" style="margin-left: auto;"><span class="name">lat</span><span class="lat" id="propLatency">--</span></div>
  </div>

  <div id="map"></div>

  <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/satellite.js@5.0.0/dist/satellite.min.js"></script>
  <script>
  // ========= USER-CONFIGURABLE: FIRMS MAP_KEY =========
  // Inject via URL ?firms_key=XXX or set window.FIRMS_MAP_KEY before this script
  const FIRMS_MAP_KEY =
    new URLSearchParams(location.search).get('firms_key') ||
    window.FIRMS_MAP_KEY ||
    null;
  // ===================================================

  // ====== HELPERS ======
  const $ = (id) => document.getElementById(id);
  const fmt = (n, d=2) => Number.isFinite(n) ? n.toFixed(d) : '--';
  const log = (...args) => console.log('[sat-ops]', ...args);

  function setProgress(pct, status) {
    $('progressBar').style.width = pct + '%';
    if (status) $('splashStatus').textContent = status;
  }
  function hideSplash() {
    const sp = $('splash');
    sp.style.opacity = '0';
    setTimeout(() => sp.style.display = 'none', 400);
  }

  // ====== GP 3LE → JSON conversion ======
  // CelesTrak returns either GP JSON (no TLE lines) or 3LE text. We use 3LE for satellite.js compatibility.
  function parse3LE(text) {
    const lines = text.split(/\r?\n/);
    const records = [];
    for (let i = 0; i + 2 < lines.length; i += 3) {
      const name = lines[i].trim();
      const l1 = lines[i + 1];
      const l2 = lines[i + 2];
      if (!name || !l1 || !l2 || !l1.startsWith('1 ') || !l2.startsWith('2 ')) continue;
      records.push({
        OBJECT_NAME: name,
        OBJECT_ID: l1.substring(2, 7).trim(),
        TLE_LINE1: l1,
        TLE_LINE2: l2,
        EPOCH: l1.substring(18, 32).trim(),
      });
    }
    return records;
  }

  // ====== DATE UTILS for GIBS fallback ======
  function dateStr(d) {
    return d.toISOString().slice(0, 10);
  }
  function dateBackoff(daysBack) {
    const d = new Date();
    d.setUTCDate(d.getUTCDate() - daysBack);
    return dateStr(d);
  }

  // ====== AOI definitions ======
  const AOIs = {
    'global':  { name: '全球', bbox: [-180, -85, 180, 85], center: [0, 20], zoom: 1 },
    'taiwan':  { name: '台海', bbox: [117, 20, 128, 28], center: [122, 24], zoom: 5 },
    'redsea':  { name: '红海', bbox: [32, 12, 45, 30], center: [38, 20], zoom: 4 },
    'ukraine': { name: '乌克兰', bbox: [22, 44, 40, 53], center: [31, 49], zoom: 5 },
    'gulf':    { name: '波斯湾', bbox: [47, 23, 58, 31], center: [52, 27], zoom: 5 },
    'suez':    { name: '苏伊士', bbox: [30, 27, 35, 33], center: [32.5, 30], zoom: 5 },
    'korea':   { name: '朝鲜半岛', bbox: [124, 33, 132, 43], center: [128, 38], zoom: 5 },
  };
  let currentAOI = 'taiwan';

  // ====== CelesTrak 3LE fetch ======
  async function fetchCelestrakGroup(groupName) {
    const url = `https://celestrak.org/NORAD/elements/gp.php?GROUP=${groupName}&FORMAT=tle`;
    const t0 = performance.now();
    const r = await fetch(url);
    if (!r.ok) throw new Error(`CelesTrak ${groupName}: HTTP ${r.status}`);
    const text = await r.text();
    const data = parse3LE(text);
    const ms = (performance.now() - t0).toFixed(0);
    log(`CelesTrak ${groupName}: ${data.length} sats in ${ms}ms (3LE)`);
    return data;
  }

  // ====== Propagate one satellite ======
  function propagateSat(gp, date) {
    if (!gp.TLE_LINE1 || !gp.TLE_LINE2) return null;
    try {
      const satrec = satellite.twoline2satrec(gp.TLE_LINE1, gp.TLE_LINE2);
      const posVel = satellite.propagate(satrec, date);
      if (!posVel.position) return null;
      const gmst = satellite.gstime(date);
      const geo = satellite.eciToGeodetic(posVel.position, gmst);
      return {
        name: gp.OBJECT_NAME,
        id: gp.OBJECT_ID,
        lat: satellite.degreesLat(geo.latitude),
        lon: satellite.degreesLong(geo.longitude),
        altKm: geo.height,
        vel: posVel.velocity,
      };
    } catch (e) {
      return null;
    }
  }

  // Compute ground track (predicted path) for next N minutes
  function groundTrack(gp, date, minutesAhead = 90, stepSec = 60) {
    if (!gp.TLE_LINE1 || !gp.TLE_LINE2) return [];
    try {
      const satrec = satellite.twoline2satrec(gp.TLE_LINE1, gp.TLE_LINE2);
      const points = [];
      for (let s = 0; s < minutesAhead * 60; s += stepSec) {
        const t = new Date(date.getTime() + s * 1000);
        const pv = satellite.propagate(satrec, t);
        if (!pv.position) continue;
        const gmst = satellite.gstime(t);
        const geo = satellite.eciToGeodetic(pv.position, gmst);
        points.push([
          satellite.degreesLong(geo.longitude),
          satellite.degreesLat(geo.latitude),
        ]);
      }
      return points;
    } catch (e) {
      return [];
    }
  }

  // ====== MapLibre setup ======
  const map = new maplibregl.Map({
    container: 'map',
    style: {
      version: 8,
      glyphs: 'https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf',
      sources: {
        // ESRI World Dark Gray — 亚太友好(国内 200), 风格近 Carto dark
        'esri-dark': {
          type: 'raster',
          tiles: ['https://server.arcgisonline.com/ArcGIS/rest/services/Canvas/World_Dark_Gray_Base/MapServer/tile/{z}/{y}/{x}'],
          tileSize: 256,
          attribution: '© Esri · Sources: Esri, HERE, Garmin, FAO, NOAA, USGS',
        },
      },
      layers: [
        { id: 'bg', type: 'background', paint: { 'background-color': '#050810' } },
        { id: 'esri-dark', type: 'raster', source: 'esri-dark' },
      ],
    },
    center: AOIs[currentAOI].center,
    zoom: AOIs[currentAOI].zoom,
    pitch: 0,
    bearing: 0,
    attributionControl: { compact: true },
  });
  map.addControl(new maplibregl.NavigationControl({ visualizePitch: false }), 'top-right');
  map.addControl(new maplibregl.ScaleControl({ unit: 'metric' }), 'bottom-right');

  // ====== Satellite state ======
  const satState = {
    stations: [], gps: [], weather: [], starlink: [],
    positions: [],     // { name, lon, lat, altKm, group, id }
    tracks: new Map(), // name → LineString coords
  };

  // ====== Load groups ======
  async function loadAllCelestrak() {
    setProgress(15, 'CelesTrak: stations / ISS…');
    try {
      satState.stations = await fetchCelestrakGroup('stations');
      setSrcStatus('celestrak', 'good', `${satState.stations.length}`);
    } catch (e) {
      setSrcStatus('celestrak', 'bad', 'fail');
      log('stations failed', e);
    }
    setProgress(35, 'CelesTrak: GPS…');
    try {
      satState.gps = await fetchCelestrakGroup('gps-ops');
    } catch (e) { log('gps failed', e); }
    setProgress(55, 'CelesTrak: weather…');
    try {
      satState.weather = await fetchCelestrakGroup('weather');
    } catch (e) { log('weather failed', e); }
    setProgress(75, 'ready (starlink lazy)');
    setSrcStatus('celestrak', 'good',
      `${satState.stations.length + satState.gps.length + satState.weather.length}`);
    repropagateAll();
  }

  function setSrcStatus(src, status, text) {
    const el = $('src-' + src);
    el.className = 'badge badge-' + (status === 'good' ? 'good' : status === 'warn' ? 'warn' : status === 'bad' ? 'bad' : 'neutral');
    el.textContent = text;
  }

  // ====== Recompute all positions for current time ======
  function repropagateAll() {
    const now = new Date();
    const all = [
      ...satState.stations.map(s => ({ ...s, group: 'stations' })),
      ...satState.gps.map(s => ({ ...s, group: 'gps' })),
      ...satState.weather.map(s => ({ ...s, group: 'weather' })),
      ...satState.starlink.map(s => ({ ...s, group: 'starlink' })),
    ];
    const positions = [];
    for (const gp of all) {
      const pos = propagateSat(gp, now);
      if (pos) positions.push({ ...pos, group: gp.group });
    }
    satState.positions = positions;
    renderSatellites();
  }

  // ====== Render satellites as MapLibre source/layers ======
  function ensureSatSource() {
    if (!map.getSource('sats')) {
      map.addSource('sats', {
        type: 'geojson',
        data: { type: 'FeatureCollection', features: [] },
      });
      map.addLayer({
        id: 'sats-track',
        type: 'line',
        source: 'sats',
        filter: ['==', ['geometry-type'], 'LineString'],
        paint: {
          'line-color': ['get', 'color'],
          'line-width': ['interpolate', ['linear'], ['zoom'], 1, 0.4, 6, 1.2],
          'line-opacity': 0.5,
        },
      });
      map.addLayer({
        id: 'sats-dot',
        type: 'circle',
        source: 'sats',
        filter: ['==', ['geometry-type'], 'Point'],
        paint: {
          'circle-radius': [
            'match', ['get', 'group'],
            'stations', 6,
            'gps', 4,
            'weather', 5,
            'starlink', 1.5,
            3,
          ],
          'circle-color': ['get', 'color'],
          'circle-stroke-color': '#ffffff',
          'circle-stroke-width': 0.5,
          'circle-opacity': 0.9,
        },
      });
      map.addLayer({
        id: 'sats-label',
        type: 'symbol',
        source: 'sats',
        filter: ['all', ['==', ['geometry-type'], 'Point'], ['==', ['get', 'showLabel'], true]],
        layout: {
          'text-field': ['get', 'name'],
          'text-size': 10,
          'text-offset': [0, 1.2],
          'text-anchor': 'top',
          'text-allow-overlap': false,
          'text-font': ['Open Sans Regular'],
        },
        paint: {
          'text-color': '#e5e7eb',
          'text-halo-color': '#050810',
          'text-halo-width': 1.2,
        },
      });
      // Click popup
      map.on('click', 'sats-dot', (e) => {
        const f = e.features[0];
        const p = f.properties;
        new maplibregl.Popup()
          .setLngLat([f.geometry.coordinates[0], f.geometry.coordinates[1]])
          .setHTML(`
            <h3>${p.name}</h3>
            <div class="meta"><b>ID:</b> ${p.id}</div>
            <div class="meta"><b>组:</b> ${p.group}</div>
            <div class="meta"><b>高度:</b> ${p.alt} km</div>
            <div class="meta"><b>位置:</b> ${fmt(p.lat, 3)}°, ${fmt(p.lon, 3)}°</div>
            <div class="meta"><b>速度:</b> ${p.speed} km/s</div>
          `).addTo(map);
      });
      map.on('mouseenter', 'sats-dot', () => map.getCanvas().style.cursor = 'pointer');
      map.on('mouseleave', 'sats-dot', () => map.getCanvas().style.cursor = '');
    }
  }

  function renderSatellites() {
    ensureSatSource();
    const showLabels = $('grp-labels').checked;
    const showTracks = $('grp-tracks').checked;
    const grpChecked = {
      stations: $('grp-stations').checked,
      gps: $('grp-gps').checked,
      weather: $('grp-weather').checked,
      starlink: $('grp-starlink').checked,
    };
    const groupColor = {
      stations: '#00d4ff',
      gps: '#10b981',
      weather: '#ff6b35',
      starlink: '#a78bfa',
    };
    const features = [];
    for (const p of satState.positions) {
      if (!grpChecked[p.group]) continue;
      const speed = p.vel ? Math.sqrt(p.vel.x*p.vel.x + p.vel.y*p.vel.y + p.vel.z*p.vel.z) : 0;
      features.push({
        type: 'Feature',
        geometry: { type: 'Point', coordinates: [p.lon, p.lat] },
        properties: {
          name: p.name,
          id: p.id,
          group: p.group,
          color: groupColor[p.group],
          alt: p.altKm ? p.altKm.toFixed(0) : '--',
          lat: p.lat,
          lon: p.lon,
          speed: speed.toFixed(2),
          showLabel: showLabels,
        },
      });
      if (showTracks) {
        const gp = [...satState.stations, ...satState.gps, ...satState.weather, ...satState.starlink]
          .find(g => g.OBJECT_ID === p.id);
        if (gp) {
          const track = groundTrack(gp, new Date(), 90, 60);
          if (track.length > 1) {
            features.push({
              type: 'Feature',
              geometry: { type: 'LineString', coordinates: track },
              properties: { color: groupColor[p.group], name: p.name },
            });
          }
        }
      }
    }
    map.getSource('sats').setData({ type: 'FeatureCollection', features });
    // Update header
    const total = satState.positions.length;
    const visible = features.filter(f => f.geometry.type === 'Point').length;
    $('countInfo').textContent = `${visible}/${total} 卫星可见 (${Object.values(grpChecked).filter(Boolean).length} 组)`;
    $('propLatency').textContent = `${(performance.now() - window._t0 || 0).toFixed(0)}ms`;
  }

  // ====== GIBS imagery layers ======
  const GIBS_LAYERS = {
    'modis-truecolor': {
      title: 'MODIS Terra 真彩合成',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/MODIS_Terra_CorrectedReflectance_TrueColor/default/{date}/GoogleMapsCompatible_Level9/{z}/{y}/{x}.jpg',
      format: 'rgb',
      opacity: 0.85,
      attr: 'NASA EOSDIS GIBS',
    },
    'viirs-nightlights': {
      title: 'VIIRS 夜光',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/VIIRS_Black_Marble/default/{date}/GoogleMapsCompatible_Level8/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.75,
      attr: 'NASA Black Marble',
    },
    'modis-aerosol': {
      title: 'MODIS 气溶胶',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/MODIS_Terra_Aerosol/default/{date}/GoogleMapsCompatible_Level7/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.7,
      attr: 'NASA MODIS',
    },
    'modis-fires-thermal': {
      title: 'MODIS 火点 (24h)',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/MODIS_Terra_Thermal_Anomalies_All/default/{date}/GoogleMapsCompatible_Level7/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.85,
      attr: 'NASA MODIS Thermal',
    },
    'gibs-clouds': {
      title: 'MODIS 云覆盖',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/MODIS_Terra_Cloud_Mask/default/{date}/GoogleMapsCompatible_Level7/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.55,
      attr: 'NASA MODIS Cloud Mask',
    },
    // --- Weather satellite real-time (Asia-Pacific priority: Himawari first) ---
    'himawari-airmass': {
      title: 'Himawari AHI 气团 (RGBA, 全彩)',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/Himawari_AHI_Air_Mass/default/{date}/GoogleMapsCompatible_Level6/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.85,
      attr: 'JMA Himawari / NASA EOSDIS GIBS',
    },
    'himawari-ir': {
      title: 'Himawari AHI 红外 (Band13, 4km)',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/Himawari_AHI_Band13_Clean_Infrared/default/{date}/GoogleMapsCompatible_Level6/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.85,
      attr: 'JMA Himawari / NASA EOSDIS GIBS',
    },
    'goes-east-airmass': {
      title: 'GOES-East ABI 气团 (RGBA)',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/GOES-East_ABI_Air_Mass/default/{date}/GoogleMapsCompatible_Level6/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.85,
      attr: 'NOAA GOES-East / NASA EOSDIS GIBS',
    },
    'goes-east-ir': {
      title: 'GOES-East ABI 红外 (Band13)',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/GOES-East_ABI_Band13_Clean_Infrared/default/{date}/GoogleMapsCompatible_Level6/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.85,
      attr: 'NOAA GOES-East / NASA EOSDIS GIBS',
    },
    'goes-west-airmass': {
      title: 'GOES-West ABI 气团 (RGBA)',
      url: 'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/GOES-West_ABI_Air_Mass/default/{date}/GoogleMapsCompatible_Level6/{z}/{y}/{x}.png',
      format: 'rgba',
      opacity: 0.85,
      attr: 'NOAA GOES-West / NASA EOSDIS GIBS',
    },
  };

  let currentImagery = 'modis-truecolor';
  let tileDateResolved = null;

  async function resolveGIBSDate(layerKey, maxBack = 5) {
    const cfg = GIBS_LAYERS[layerKey];
    const tileUrl = cfg.url
      .replace('{date}', dateStr(new Date()))
      .replace('{z}', '2').replace('{y}', '1').replace('{x}', '2');
    // Try today, then back off up to maxBack days. GIBS returns small (empty) JPEG (~1-2KB) for future/no-data dates.
    for (let i = 0; i <= maxBack; i++) {
      const date = dateBackoff(i);
      const url = cfg.url
        .replace('{date}', date)
        .replace('{z}', '2').replace('{y}', '1').replace('{x}', '2');
      try {
        const r = await fetch(url, { method: 'HEAD' });
        if (r.ok) {
          const len = r.headers.get('content-length');
          // Empty/placeholder tiles are usually < 2KB
          if (len && parseInt(len) > 3000) {
            return { date, backoffDays: i };
          }
        }
      } catch (e) { /* CORS may block HEAD; we fall back to GET below */ }
    }
    // Fallback: assume today
    return { date: dateStr(new Date()), backoffDays: 0 };
  }

  async function applyImagery(layerKey) {
    if (layerKey === 'off') {
      // remove all imagery layers
      Object.keys(GIBS_LAYERS).forEach(k => {
        const lid = 'gibs-' + k;
        if (map.getLayer(lid)) map.removeLayer(lid);
        if (map.getSource(lid)) map.removeSource(lid);
      });
      currentImagery = 'off';
      $('tileDate').textContent = 'off';
      $('tileFallback').textContent = '--';
      // Update buttons
      document.querySelectorAll('.layer-btn').forEach(b => b.classList.toggle('active', b.dataset.layer === 'off'));
      return;
    }
    const cfg = GIBS_LAYERS[layerKey];
    if (!cfg) return;
    setSrcStatus('gibs', 'warn', 'resolving…');
    const { date, backoffDays } = await resolveGIBSDate(layerKey, 5);
    tileDateResolved = date;
    $('tileDate').textContent = date;
    $('tileFallback').textContent = backoffDays === 0 ? 'today' : `back ${backoffDays}d`;

    // remove all existing gibs layers first
    Object.keys(GIBS_LAYERS).forEach(k => {
      const lid = 'gibs-' + k;
      if (map.getLayer(lid)) map.removeLayer(lid);
      if (map.getSource(lid)) map.removeSource(lid);
    });

    const srcId = 'gibs-' + layerKey;
    map.addSource(srcId, {
      type: 'raster',
      tiles: [cfg.url.replace('{date}', date)],
      tileSize: 256,
      attribution: cfg.attr,
    });
    map.addLayer({
      id: srcId,
      type: 'raster',
      source: srcId,
      paint: { 'raster-opacity': cfg.opacity, 'raster-opacity-transition': { duration: 300 } },
    });
    // Move satellite layers above
    ['sats-track', 'sats-dot', 'sats-label'].forEach(lid => {
      if (map.getLayer(lid)) map.moveLayer(lid);
    });
    currentImagery = layerKey;
    setSrcStatus('gibs', 'good', date);
    // Update buttons
    document.querySelectorAll('.layer-btn').forEach(b => b.classList.toggle('active', b.dataset.layer === layerKey));
  }

  // ====== FIRMS active fires ======
  async function loadFirms(aoiKey) {
    if (!FIRMS_MAP_KEY) {
      setSrcStatus('firms', 'neutral', 'no-key');
      $('firmsStatus').textContent = 'FIRMS 未配置';
      $('firmsStatus').className = 'badge badge-neutral';
      return;
    }
    const aoi = AOIs[aoiKey] || AOIs.global;
    const url = `https://firms.modaps.eosdis.nasa.gov/api/area/csv/MODIS_NRT/${aoi.bbox.join(',')}/1/${FIRMS_MAP_KEY}`;
    try {
      setSrcStatus('firms', 'warn', 'loading…');
      const r = await fetch(url);
      if (!r.ok) throw new Error('HTTP ' + r.status);
      const text = await r.text();
      const lines = text.trim().split('\n');
      const header = lines[0].split(',');
      const features = [];
      for (let i = 1; i < lines.length; i++) {
        const cells = lines[i].split(',');
        const row = {};
        header.forEach((h, j) => row[h.trim()] = cells[j]?.trim());
        features.push({
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [parseFloat(row.longitude), parseFloat(row.latitude)] },
          properties: {
            brightness: parseFloat(row.brightness) || 0,
            confidence: row.confidence,
            frp: parseFloat(row.frp) || 0,
            satellite: row.satellite,
            instrument: row.instrument,
            acq: `${row.acq_date} ${row.acq_time}`,
          },
        });
      }
      $('firmsCount').textContent = features.length.toString();
      $('firmsStatus').textContent = `${features.length} 点`;
      $('firmsStatus').className = features.length ? 'badge badge-warn' : 'badge badge-good';
      setSrcStatus('firms', 'good', features.length);
      renderFirms(features);
    } catch (e) {
      log('FIRMS failed', e);
      setSrcStatus('firms', 'bad', 'fail');
    }
  }

  function renderFirms(features) {
    if (map.getSource('firms')) map.removeSource('firms');
    if (map.getLayer('firms-pts')) map.removeLayer('firms-pts');
    map.addSource('firms', { type: 'geojson', data: { type: 'FeatureCollection', features } });
    map.addLayer({
      id: 'firms-pts',
      type: 'circle',
      source: 'firms',
      paint: {
        'circle-radius': [
          'interpolate', ['linear'], ['zoom'], 1, 2, 8, 6,
        ],
        'circle-color': [
          'interpolate', ['linear'], ['get', 'brightness'],
          300, '#ffd166', 360, '#ff6b35', 400, '#ef4444',
        ],
        'circle-stroke-color': '#ffffff',
        'circle-stroke-width': 0.3,
        'circle-opacity': 0.85,
      },
    });
  }

  // ====== STAC (Earth Search) ======
  async function loadSTAC(aoiKey) {
    const aoi = AOIs[aoiKey] || AOIs.global;
    const now = new Date();
    const past = new Date(now.getTime() - 7 * 24 * 3600 * 1000);
    const body = {
      collections: ['sentinel-2-l2a'],
      bbox: aoi.bbox,
      datetime: `${dateStr(past)}T00:00:00Z/${dateStr(now)}T23:59:59Z`,
      limit: 50,
      query: { 'eo:cloud_cover': { lte: 30 } },
    };
    setSrcStatus('stac', 'warn', 'querying…');
    try {
      const r = await fetch('https://earth-search.aws.element84.com/v1/search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!r.ok) throw new Error('HTTP ' + r.status);
      const data = await r.json();
      const features = data.features || [];
      $('stacCount').textContent = features.length.toString();
      setSrcStatus('stac', 'good', features.length);
      renderSTACFootprints(features);
    } catch (e) {
      log('STAC failed', e);
      setSrcStatus('stac', 'bad', 'fail');
    }
  }

  function renderSTACFootprints(features) {
    if (map.getSource('stac')) map.removeSource('stac');
    if (map.getLayer('stac-fill')) map.removeLayer('stac-fill');
    if (map.getLayer('stac-line')) map.removeLayer('stac-line');
    map.addSource('stac', { type: 'geojson', data: { type: 'FeatureCollection', features } });
    map.addLayer({
      id: 'stac-fill',
      type: 'fill',
      source: 'stac',
      paint: { 'fill-color': '#00d4ff', 'fill-opacity': 0.08 },
    });
    map.addLayer({
      id: 'stac-line',
      type: 'line',
      source: 'stac',
      paint: { 'line-color': '#00d4ff', 'line-width': 1, 'line-dasharray': [2, 2], 'line-opacity': 0.6 },
    });
  }

  // ====== Starlink lazy load ======
  async function loadStarlink() {
    setSrcStatus('celestrak', 'warn', 'starlink 10k loading…');
    setProgress(85, 'CelesTrak: starlink (10k 颗, 4MB)...');
    try {
      satState.starlink = await fetchCelestrakGroup('starlink');
      // Limit to first 500 for render perf (full 10k would lag browser)
      const prev = satState.starlink.length;
      satState.starlink = satState.starlink.slice(0, 500);
      log(`Starlink: kept ${satState.starlink.length}/${prev} for render`);
      repropagateAll();
    } catch (e) {
      log('starlink failed', e);
    }
  }

  // ====== UI wiring ======
  function wireUI() {
    document.querySelectorAll('[id^="grp-"]').forEach(el => {
      el.addEventListener('change', () => {
        if (el.id === 'grp-starlink' && el.checked && satState.starlink.length === 0) {
          loadStarlink();
        }
        renderSatellites();
      });
    });
    document.querySelectorAll('.layer-btn').forEach(btn => {
      btn.addEventListener('click', () => applyImagery(btn.dataset.layer));
    });
    document.querySelectorAll('.aoi-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.aoi-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentAOI = btn.dataset.aoi;
        const aoi = AOIs[currentAOI];
        map.flyTo({ center: aoi.center, zoom: aoi.zoom, duration: 1200 });
        if (FIRMS_MAP_KEY) loadFirms(currentAOI);
        loadSTAC(currentAOI);
      });
    });
  }

  // ====== Clock + auto-repropagation ======
  function tickClock() {
    const now = new Date();
    $('clock').textContent = now.toISOString().slice(0, 19).replace('T', ' ') + ' UTC';
  }
  setInterval(tickClock, 1000);
  setInterval(repropagateAll, 60000); // re-propagate every 60s

  // ====== INIT ======
  window._t0 = performance.now();
  map.on('load', async () => {
    try {
      setProgress(5, 'map ready');
      wireUI();
      tickClock();
      await loadAllCelestrak();
      setProgress(80, 'GIBS imagery…');
      await applyImagery('modis-truecolor');
      if (FIRMS_MAP_KEY) await loadFirms(currentAOI);
      await loadSTAC(currentAOI);
      setProgress(100, 'ready');
    } catch (e) {
      console.error('[init] error', e);
      $('splashStatus').textContent = '部分初始化失败 (tiles 可能受限): ' + e.message.slice(0, 60);
    } finally {
      // Always hide splash after 5s max, even if a step stalls
      setTimeout(hideSplash, 800);
    }
    // Init latency
    $('propLatency').textContent = `${(performance.now() - window._t0).toFixed(0)}ms`;
  });

  // Hard splash kill-switch (12s)
  setTimeout(() => {
    if ($('splash').style.display !== 'none') {
      console.warn('[init] splash kill-switch fired (12s)');
      hideSplash();
    }
  }, 12000);

  // Splash error handler
  window.addEventListener('error', (e) => {
    log('window error', e.message);
  });
  </script>
</body>
</html>