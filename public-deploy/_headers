# rocket-launch-db + rockets paths — force no-cache
/db/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0, private
  Pragma: no-cache
  Expires: 0

/rockets/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0, private
  Pragma: no-cache
  Expires: 0

/rocket-launch-db*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0, private
  Pragma: no-cache
  Expires: 0

# Daily reports — same no-cache
/daily-reports*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0, private
  Pragma: no-cache

# diag + diagnostic pages — also no-cache
/diag*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0, private
  Pragma: no-cache

# Everything else — short cache (1 hour)
/*
  Cache-Control: public, max-age=3600
