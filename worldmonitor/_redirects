# Cloudflare Pages _redirects for /worldmonitor/ subpath
# worldmonitor-cn vite plugin renames index.html → dashboard.html
# (PITFALL #25 — single-file + directory coexistence). We expose both
# entries: index.html as the canonical landing page, dashboard.html as
# the alternative URL the vercel-edge-style rewrites expect.

# Entry fallback: /worldmonitor/ → /worldmonitor/index.html
# All entry forms append ?variant=china so the SPA's URLSearchParams check
# in src/config/variant.ts confirms china explicitly (in addition to the
# pathname-based override added in the same commit). Belt and suspenders so
# the china SPA boots regardless of which redirect rule fires first.
/worldmonitor/         /worldmonitor/?variant=china    302
/worldmonitor          /worldmonitor/?variant=china    302

# Known static pages — same variant pin, append ?variant=china
/worldmonitor/embed        /worldmonitor/embed.html?variant=china      302
/worldmonitor/embed.html   /worldmonitor/embed.html?variant=china      302
/worldmonitor/live-channels /worldmonitor/live-channels.html?variant=china 302
/worldmonitor/settings      /worldmonitor/settings.html?variant=china   302
/worldmonitor/mcp-grant     /worldmonitor/mcp-grant.html?variant=china  302

# Asset paths (built HTML uses root-relative /worldmonitor/assets/...,
# but if a stale/older build ever lands without the prefix, this catches it)
/assets/*              /assets/:splat                 200
/worldmonitor/assets/* /assets/:splat                 200

# Known data paths (Vite bundles /data/* in dist root; allow both)
/worldmonitor/data/*  /data/:splat  200
